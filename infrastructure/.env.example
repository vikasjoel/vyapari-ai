# AWS Credentials & Region
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID

# AgentCore (filled after agent deployment)
AGENTCORE_SUPERVISOR_ARN=
AGENTCORE_MEMORY_ID=

# Bedrock Models
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514
BEDROCK_EMBEDDING_MODEL_ID=amazon.nova-2-multimodal-embeddings-v1:0
BEDROCK_KB_ID=

# DynamoDB Tables
DYNAMODB_MERCHANTS_TABLE=vyapari-merchants
DYNAMODB_PRODUCTS_TABLE=vyapari-products
DYNAMODB_ORDERS_TABLE=vyapari-orders
DYNAMODB_SESSIONS_TABLE=vyapari-sessions

# S3 Buckets (append your account ID for uniqueness)
S3_PHOTOS_BUCKET=vyapari-photos-YOUR_ACCOUNT_ID
S3_PRODUCT_KB_BUCKET=vyapari-product-kb-YOUR_ACCOUNT_ID
S3_VOICE_BUCKET=vyapari-voice-YOUR_ACCOUNT_ID
S3_WEB_BUCKET=vyapari-web-YOUR_ACCOUNT_ID

# Transcribe
TRANSCRIBE_CUSTOM_VOCABULARY=vyapari-hindi-vocab
TRANSCRIBE_LANGUAGE=hi-IN

# Polly
POLLY_VOICE_ID=Aditi
POLLY_ENGINE=neural
POLLY_LANGUAGE=hi-IN

# Translate
TRANSLATE_SOURCE=hi
TRANSLATE_TARGETS=ta,te,bn,en

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# CloudFront (filled after deployment)
CLOUDFRONT_DISTRIBUTION_ID=
CLOUDFRONT_DOMAIN=
